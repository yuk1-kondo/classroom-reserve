rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 管理者権限チェック（Firestore ドキュメントベース）
    function isAdmin() {
      return request.auth != null && (
        // UIDベース
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid)) ||
        // メールアドレスベース（admin_users/{email} も許可）
        (request.auth.token.email != null &&
          exists(/databases/$(database)/documents/admin_users/$(request.auth.token.email)))
      );
    }
    
    // 認証済みユーザーかチェック
    function isAuthenticated() {
      return request.auth != null;
    }

    // 進路指導部など：会議室の先日付特例メンバーか
    // guidance_group_members/{uid}.active が false のときは無効（クライアント guidancePrivilegeService.isGuidanceMember と同じ）
    function isGuidanceGroupMember() {
      return request.auth != null
        && exists(/databases/$(database)/documents/guidance_group_members/$(request.auth.uid))
        && get(/databases/$(database)/documents/guidance_group_members/$(request.auth.uid)).data.active != false;
    }

    // 特例の対象教室（system_settings/guidance_privilege.meetingRoomId と一致）
    function isGuidanceMeetingRoomReservation() {
      return exists(/databases/$(database)/documents/system_settings/guidance_privilege)
        && request.resource.data.roomId
          == get(/databases/$(database)/documents/system_settings/guidance_privilege).data.meetingRoomId;
    }

    // 理科グループ：実験室などの利用メンバーか（science_group_members / active は進路と同様）
    function isScienceGroupMember() {
      return request.auth != null
        && exists(/databases/$(database)/documents/science_group_members/$(request.auth.uid))
        && get(/databases/$(database)/documents/science_group_members/$(request.auth.uid)).data.active != false;
    }

    // 教室ドキュメントが理科グループ専用か（rooms.scienceGroupOnly == true）
    function roomIsScienceGroupOnly(roomId) {
      return exists(/databases/$(database)/documents/rooms/$(roomId))
        && get(/databases/$(database)/documents/rooms/$(roomId)).data.scienceGroupOnly == true;
    }

    // 管理者ユーザー管理コレクション
    match /admin_users/{userId} {
      // 認証済みユーザーは読み取り可能（管理者判定のため）
      allow read: if isAuthenticated();
      // 管理者のみ書き込み可能
      allow write: if isAdmin();
    }

    // ユーザープロファイル（UID→emailマップ）
    match /user_profiles/{uid} {
      // 読み取り: 認証済みユーザー（管理者追加時に逆引きするため）
      allow read: if isAuthenticated();
      // 書き込み: 認証済み本人のみ（ログイン時の upsert 用）
      allow write: if isAuthenticated() && request.auth.uid == uid;
    }

    // ユーザーアクセス管理（ログイン済みユーザー一覧 + アクセス制御）
    match /user_access/{uid} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        request.auth.uid == uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // 管理者が user_access から削除した UID（同期・再ログインで再作成しない）
    match /user_access_exclusions/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    // 進路指導部など：先日付特例メンバー（UID=ドキュメントID）
    match /guidance_group_members/{memberUid} {
      allow read: if isAuthenticated() && (request.auth.uid == memberUid || isAdmin());
      allow write: if isAdmin();
    }

    // 理科グループメンバー（UID=ドキュメントID）
    match /science_group_members/{memberUid} {
      allow read: if isAuthenticated() && (request.auth.uid == memberUid || isAdmin());
      allow write: if isAdmin();
    }

    // 教室：メタデータの読取は認証済みに許可（一覧は getDocs 全件になるため、
    // ドキュメントごとの条件だけだと「理科専用が1件でもあると一般ユーザーの一覧クエリ全体が拒否」になる）。
    // 理科専用の非表示はクライアント filterScienceOnlyRoomsForViewer と予約ルールで担保する。
    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /periods/{periodId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 予約情報：一覧は startTime 範囲クエリのため「読めるドキュメントのみ返す」方式と整合させる（ルールをフィルタにできない）。
    // 理科専用の非表示は台帳UI・教室一覧のフィルタで担保。認証済みなら読取可。
    match /reservations/{reservationId} {
      allow read: if isAuthenticated();
      // 作成は認証済み + 作成者一致 + 先日付制限内（設定が存在すれば）
      // 管理者の場合は日付制限をスキップ
      // 理科専用教室への予約は理科メンバーまたは管理者のみ
      // 先日付は管理UIで運用。作成は本人のみ（理科専用の拒否はデータ不整合で誤爆しやすいため create では room 参照しない）
      allow create: if isAuthenticated()
        && request.resource.data.createdBy == request.auth.uid;
    // 更新は作成者 または 管理者（理科専用へ変更・維持は理科メンバーまたは管理者のみ）
    allow update: if isAuthenticated()
      && (request.auth.uid == resource.data.createdBy || isAdmin())
      && (!roomIsScienceGroupOnly(request.resource.data.roomId) || isAdmin() || isScienceGroupMember());
    // 削除は作成者 または 管理者 または 会議室予約（パスコード認証はクライアント側で実施）
    // 理科専用の予約の削除は作成者・管理者・理科メンバー（会議室と同様にクライアントで運用）
    allow delete: if isAuthenticated()
      && (!roomIsScienceGroupOnly(resource.data.roomId) || isAdmin() || isScienceGroupMember() || request.auth.uid == resource.data.createdBy)
      && (
        request.auth.uid == resource.data.createdBy ||
        isAdmin() ||
        resource.data.roomName == '会議室'
      );
    }

    // 予約スロット（同時予約防止）。トランザクションで「未作成スロット」を get するため、
    // read は認証済みに許可（存在しない doc でも resource.data を評価できず拒否されないようにする）。
    // 作成・更新・削除は引き続き理科専用教室をルールで制限。
    match /reservation_slots/{slotId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }

    // 月次サマリー（現在は利用していないが削除処理の整合性維持に必要）
    match /month_overview/{monthId} {
      allow read: if true;
      // 運用上問題ないため認証済みユーザーに書き込みを許可
      allow write: if isAuthenticated();
    }

    // システム設定（予約制限など）
    match /system_settings/{docId} {
      // 誰でも読み取り可能（UI 表示用）。必要に応じて認証済みに制限可。
      allow read: if true;
      // 書き込みは管理者のみ
      allow write: if isAdmin();
    }

    // 固定（毎週）予約テンプレート
    match /weekly_templates/{templateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 予約禁止期間（管理者が設定、一般ユーザーは読み取りのみ）
    match /blocked_periods/{blockId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
